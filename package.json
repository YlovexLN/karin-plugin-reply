{
  "name": "karin-plugin-reply",
  "version": "0.0.7",
  "description": "Karin 自定义关键词回复插件，支持群聊/私聊，支持群组专属规则",
  "keywords": [
    "karin",
    "karin-plugin",
    "qq-bot",
    "keyword-reply",
    "chatbot",
    "automation"
  ],
  "homepage": "https://github.com/YlovexLN/karin-plugin-reply",
  "bugs": {
    "url": "https://github.com/YlovexLN/karin-plugin-reply/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YlovexLN/karin-plugin-reply.git"
  },
  "author": "YlovexLN <ylovexln@foxmail.com>",
  "license": "GPL-3.0",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "app": "karin start",
    "dev": "karin dev",
    "init": "karin init",
    "start": "karin start",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-version.js",
    "sync-version": "node scripts/sync-version.js",
    "setup:husky": "node scripts/setup-husky.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "neostandard": "^0.12.0"
  },
  "peerDependencies": {
    "node-karin": "^1.15.1"
  },
  "karin": {
    "apps": [
      "lib/apps"
    ],
    "static": [
      "resources"
    ],
    "files": [
      "config",
      "resources"
    ],
    "include": [
      "src/**/*"
    ],
    "exclude": [
      "lib/**/*",
      "@karinjs/**/*"
    ],
    "web": "./lib/web.config.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
